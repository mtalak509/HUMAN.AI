# HUMAN.AI - пример конфигурации

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# Обязательно. Тот же пароль подставляется в docker-compose через ${NEO4J_PASSWORD}.
NEO4J_PASSWORD=changeme

# Qdrant
QDRANT_URL=http://localhost:6333

# Redis
REDIS_URL=redis://localhost:6379

# Логирование
# Уровни: TRACE | DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# JSON-режим для ELK/prod: true / false
LOG_JSON=false

# Хранилище документов
# Корень для PDF + text.md: {STORAGE_ROOT}/documents/{document_id}/
STORAGE_ROOT=storage

# LLM-экстрактор (OpenRouter) — Фаза 5
# Секрет: задаётся только здесь/в окружении, кодом читается из Settings (не os.getenv) и не логируется.
OPENROUTER_API_KEY=
EXTRACTOR_MODEL=qwen/qwen3.6-plus
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Таймаут LLM-вызова, секунды
EXTRACTOR_TIMEOUT=60.0
# Температура сэмплирования
EXTRACTOR_TEMPERATURE=0.0
