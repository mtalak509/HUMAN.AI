# HUMAN.AI - пример конфигурации
# Скопируйте в .env и заполните значения

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Qdrant
QDRANT_URL=http://localhost:6333

# Redis
REDIS_URL=redis://localhost:6379

# Логирование
# Уровни: TRACE | DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# JSON-режим для ELK/prod: true / false
LOG_JSON=false
